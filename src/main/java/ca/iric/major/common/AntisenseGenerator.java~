package ca.iric.major.common;

/**
 * Antisense genertor produces a String generator for antisense with 4-nt and 3-nt grips for, respectively, seed and supp.
 *    this generator is lazy and cheap (does not generate all possible sequences), keeps one sequence at a time.
 *
 * @version 1.0
 * @author Francois Major
 * @copyright 1.0 2025 - MajorLab, IRIC, Universite de Montreal
 * @license MIT
*/

import java.util.Iterator;
import java.util.NoSuchElementException;
import java.util.function.Predicate;

/**
 * Lazy generator of antisense sequences of length 21 with:
 *
 *   - g1 (index 0) = 'C'
 *   - g10 (index 9) = 'A'  (could also be 'U' if you want to add variation)
 *   - g11 (index 10) != 'C' (we fix it to 'U')
 *   - last three nucleotides = "AUU"
 *
 * The 4-nt seed grip and 3-nt supplementary grip are embedded at fixed
 * positions:
 *
 *   - seedGrip (4 nt) at indices 1..4  (positions 2..5, g2..g5)
 *   - suppGrip (3 nt) at indices 12..14 (positions 13..15, g13..g15)
 *
 * To avoid exploding the search space, only five positions are varied:
 *   variable positions = { 5, 6, 7, 15, 16 } (0-based indices)
 *
 * Each of these can be any of {A, C, G, U}, so we get 4^5 = 1024 variants.
 *
 * The provided Predicate<String> filter is applied on-the-fly; sequences that
 * do not pass the filter are skipped.
 *
 * This implementation is fully lazy: it keeps only the next sequence to be
 * served in memory and enumerates variants on demand.
 */
public class AntisenseGenerator implements Iterator<String> {

    private static final char[] ALPHABET = { 'A', 'C', 'G', 'U' };
    private static final int MAX_VARIANTS = 1024; // 4^5

    private final String seedGrip;      // length 4
    private final String suppGrip;      // length 3
    private final Predicate<String> filter;

    // index of the next variant to TRY (0..MAX_VARIANTS)
    private int variantIndex = 0;

    // cache for the next accepted sequence
    private String nextSequence = null;
    private boolean nextPrepared = false;

    public AntisenseGenerator(String seedGrip, String suppGrip, Predicate<String> filter) {
        if (seedGrip == null || seedGrip.length() != 4) {
            throw new IllegalArgumentException("seedGrip must be 4 nt");
        }
        if (suppGrip == null || suppGrip.length() != 3) {
            throw new IllegalArgumentException("suppGrip must be 3 nt");
        }
        if (filter == null) {
            throw new IllegalArgumentException("filter must not be null");
        }
        this.seedGrip = seedGrip;
        this.suppGrip = suppGrip;
        this.filter = filter;
    }

    @Override
    public boolean hasNext() {
        if (!nextPrepared) {
            prepareNext();
        }
        return nextSequence != null;
    }

    @Override
    public String next() {
        if (!hasNext()) {
            throw new NoSuchElementException("AntisenseGenerator exhausted");
        }
        String result = nextSequence;
        // Mark cache as consumed; next call will advance the variantIndex further.
        nextPrepared = false;
        nextSequence = null;
        return result;
    }

    /**
     * Enumerate variants until one passes the filter or we run out of variants.
     */
    private void prepareNext() {
        // Already prepared
        if (nextPrepared) return;

        while (variantIndex < MAX_VARIANTS) {
            String candidate = buildVariant(variantIndex);
            variantIndex++;  // increment for next attempt

            if (filter.test(candidate)) {
                nextSequence = candidate;
                nextPrepared = true;
                return;
            }
        }

        // No more variants
        nextSequence = null;
        nextPrepared = true;
    }

    /**
     * Build the antisense sequence corresponding to a given integer index
     * in [0, MAX_VARIANTS). The index is interpreted in base-4 to fill
     * the five variable positions {5, 6, 7, 15, 16}.
     */
    private String buildVariant(int index) {
        char[] seq = new char[21];

        // 1) Fixed structural constraints
        seq[0]  = 'C';   // g1
        seq[9]  = 'A';   // g10 (could randomize A/U if desired)
        seq[10] = 'U';   // g11 != 'C'
        seq[18] = 'A';   // last three = AUU
        seq[19] = 'U';
        seq[20] = 'U';

        // 2) Embed seedGrip at indices 1..4 (g2..g5)
        for (int i = 0; i < 4; i++) {
            seq[1 + i] = seedGrip.charAt(i);
        }

        // 3) Embed suppGrip at indices 12..14 (g13..g15)
        for (int i = 0; i < 3; i++) {
            seq[12 + i] = suppGrip.charAt(i);
        }

        // 4) Choose some fixed "neutral" bases for the remaining non-variable slots
        //    (these are arbitrary but consistent and respect no-extra constraints)
        // Indices 8, 11, 17 we fix arbitrarily:
        seq[8]  = 'G';
        seq[11] = 'A';   // still respects "g11 != C"
        seq[17] = 'A';

        // 5) Fill variable positions based on index in base-4
        // variableIndices.length == 5, hence 4^5 = 1024 variants
        int[] variableIndices = { 5, 6, 7, 15, 16 };

        int value = index;
        for (int pos = variableIndices.length - 1; pos >= 0; pos--) {
            int digit = value & 0b11;   // value % 4
            value >>= 2;                // value /= 4
            seq[variableIndices[pos]] = ALPHABET[digit];
        }

        return new String(seq);
    }
}
